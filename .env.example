# ─── Pricing Mentor AI Configuration ─────────────────────────────────────────
# Configure one or more AI providers. The system tries them in order:
# 1. DeepSeek (primary)
# 2. OpenAI (secondary)
# 3. Groq (tertiary)
# 4. Google Gemini (quaternary)
# 5. Local knowledge base (always available as final fallback)

# DeepSeek API (primary – recommended)
# Get your key at: https://platform.deepseek.com/
VITE_DEEPSEEK_API_KEY=

# OpenAI API (optional fallback)
# Get your key at: https://platform.openai.com/
VITE_OPENAI_API_KEY=

# Groq API (optional fallback – fast inference for open-source models)
# Get your key at: https://console.groq.com/
VITE_GROQ_API_KEY=

# Google Gemini API (optional fallback)
# Get your key at: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=
